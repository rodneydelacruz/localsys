[
  {
    "name": "document_requests",
    "type": "base",
    "system": false,
    "schema": [
      { "name": "queue_number", "type": "text", "required": true, "options": { "max": 10 } },
      { "name": "resident_id", "type": "relation", "required": true, "options": { "collectionId": "", "maxSelect": 1 } },
      { "name": "resident_name", "type": "text", "required": true, "options": { "max": 255 } },
      { "name": "document_type", "type": "select", "required": true, "options": { "values": ["barangay_clearance", "business_permit", "certificate_of_indigency", "certificate_of_residency", "certificate_of_good_moral", "cedula", "other"] } },
      { "name": "other_document_type", "type": "text", "options": { "max": 255 } },
      { "name": "purpose", "type": "text", "required": true, "options": { "max": 2000 } },
      { "name": "status", "type": "select", "required": true, "options": { "values": ["pending", "processing", "for_release", "released", "cancelled"] } },
      { "name": "assigned_to", "type": "relation", "options": { "collectionId": "", "maxSelect": 1 } },
      { "name": "notes", "type": "text", "options": { "max": 2000 } },
      { "name": "requested_at", "type": "autodate", "options": { "when": "create" } },
      { "name": "released_at", "type": "date" },
      { "name": "received_by", "type": "text", "options": { "max": 255 } }
    ],
    "indexes": [
      "CREATE INDEX idx_docreq_queue ON document_requests (queue_number)",
      "CREATE INDEX idx_docreq_status ON document_requests (status)",
      "CREATE INDEX idx_docreq_type ON document_requests (document_type)",
      "CREATE INDEX idx_docreq_resident ON document_requests (resident_id)"
    ],
    "listRule": "@request.auth.id != ''",
    "viewRule": "@request.auth.id != ''",
    "createRule": "@request.auth.role = 'admin' || @request.auth.role = 'staff'",
    "updateRule": "@request.auth.role = 'admin' || @request.auth.role = 'staff'",
    "deleteRule": "@request.auth.role = 'admin' || @request.auth.role = 'staff'"
  }
]
